# ──────────────────────────────────────────────────────────────────────────────
# API Auth Proxy — Environment Configuration
#
# INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in the values below (especially ADMIN_SECRET)
#   3. Never commit .env to git (it's in .gitignore)
# ──────────────────────────────────────────────────────────────────────────────

# REQUIRED: Secret key for admin endpoints (X-Admin-Secret header)
# Generate a strong one with: openssl rand -hex 32
ADMIN_SECRET=change_me_to_a_strong_random_secret_at_least_32_chars

# Port exposed to the host machine (Nginx will proxy to this)
# Default: 8000
PROXY_PORT=8000

# Rate limiting (requests per hour per API key)
# Default: 100
RATE_LIMIT_PER_HOUR=100

# Key expiry in days after creation
# Default: 30
KEY_EXPIRY_DAYS=30

# Log verbosity: DEBUG | INFO | WARNING | ERROR
# Default: INFO
LOG_LEVEL=INFO
